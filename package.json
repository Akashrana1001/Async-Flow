{
  "name": "backend-task-queue",
  "version": "1.0.0",
  "description": "A distributed task queue system using Node.js, Express, Redis, and BullMQ for processing background jobs asynchronously.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "worker": "node workers/jobWorker.js",
    "dev": "nodemon server.js"
  },
  "keywords": [
    "task-queue",
    "bullmq",
    "redis",
    "background-jobs",
    "distributed-systems"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bullmq": "^5.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
